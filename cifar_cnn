#@title Libs

import torch
import torchvision
import torch.nn as nn
import torchvision.transforms as transforms

import matplotlib.pyplot as plt
import numpy as np
from sklearn import metrics

from tqdm import tqdm

#@title Dataset Setup

train_transform = transforms.Compose(
    [transforms.RandomHorizontalFlip(p=0.5),
     transforms.RandomCrop(32, padding=4),
     transforms.ColorJitter(brightness=0.2, contrast=0.2, saturation=0.2),
     transforms.ToTensor(),
     transforms.Normalize((0.4914, 0.4822, 0.4465), (0.247, 0.243, 0.261))])

test_transform = transforms.Compose(
    [transforms.ToTensor(),
     transforms.Normalize((0.4914, 0.4822, 0.4465), (0.247, 0.243, 0.261))])

train_dataset = torchvision.datasets.CIFAR10(root='./data', train=True, download=True, transform=train_transform)
test_dataset = torchvision.datasets.CIFAR10(root='./data', train=False, download=True, transform=test_transform)#Usando os dados de normalização do CIFAR-10, que são as médias e desvios padrão de cada canal (R, G, B) do dataset. Isso ajuda a estabilizar o processo de treinamento e melhorar a convergência do modelo.

#fazendo data augmentation para melhorar a generalização do modelo, com flip horizontal, crop aleatório e ajustes de brilho, contraste e saturação. Além disso, normalizamos os dados usando as médias e desvios padrão do dataset CIFAR-10.

"""### Defining the CNN model
Here we adapt the LeNet-5 architecture introduced in [*Gradient-based learning applied to document recognition*](https://ieeexplore.ieee.org/document/726791), originally developed to classify handwritten digits.

![lenet5](https://www.researchgate.net/publication/359784095/figure/fig2/AS:11431281079624737@1660789284522/Example-of-a-CNN-LeNet-5-14-is-able-to-identify-handwritten-digits-for-zip-code.png)


The main change we made here is the number of in/out channels, kernel sizes, padding, etc (enabling better results). It has 2 convolutional layers followed by 2 pooling (subsampling) layers. After the conv. blocks, we pass the feature maps through 2 hidden fully-connected layers to get the most activated neuron with the softmax function. If you want a more detailed explanation, [check this link](https://www.datasciencecentral.com/lenet-5-a-classic-cnn-architecture/) or reach us on Discord :)
"""

class CNN(nn.Module):
  def __init__(self):
    super(CNN, self).__init__()
    #adionada batch normalization para ajudar a estabilizar o processo de treinamento e melhorar a convergência do modelo. A batch normalization é aplicada após as camadas convolucionais para normalizar as ativações e reduzir o desvio interno, o que pode levar a uma melhor performance e acurácia do modelo.
    self.conv1 = nn.Conv2d(3, 128, kernel_size=3, padding=1)
    self.bn1 = nn.BatchNorm2d(128)
    self.conv2 = nn.Conv2d(128, 256, kernel_size=3, padding=1)
    self.bn2 = nn.BatchNorm2d(256)

    #aumentada a quantidade de filtros para 64 e 128, respectivamente, para permitir que o modelo capture mais características e padrões complexos nas imagens, o que pode levar a uma melhor acurácia. Além disso, mantivemos o kernel size de 3x3 e o padding de 1 para preservar as dimensões das imagens durante as convoluções.

    self.pool = nn.MaxPool2d(kernel_size=2, stride=2)

    self.fc_hidden1 = nn.Linear(256 * 8 * 8, 512)
    self.fc_hidden2 = nn.Linear(512, 256)
    self.fc_output = nn.Linear(256, 10)

    self.dropout = nn.Dropout(p=0.5)

  def forward(self, x):
    x = self.bn1(self.conv1(x))
    x = nn.ReLU()(x)
    x = self.pool(x)
    
    x = self.bn2(self.conv2(x))
    x = nn.ReLU()(x)
    x = self.pool(x)
    

    #adicionando o dropout após as camadas convolucionais para ajudar a prevenir o overfitting, e também antes das camadas totalmente conectadas para melhorar a generalização do modelo. O dropout é aplicado com uma taxa de 0.5, o que significa que metade dos neurônios será desligada aleatoriamente durante o treinamento.
    x = x.view(x.size(0), -1)
    x = self.dropout(nn.ReLU()(self.fc_hidden1(x)))
    x = self.dropout(nn.ReLU()(self.fc_hidden2(x)))
    x = self.fc_output(x)
    return x
#@title Defining metrics helper

def get_scores(targets, predictions):
    return {
        "accuracy": metrics.accuracy_score(targets, predictions),
        "balanced_accuracy": metrics.balanced_accuracy_score(targets, predictions),
        "precision": metrics.precision_score(targets, predictions, average="weighted"),
        "recall": metrics.recall_score(targets, predictions, average="weighted"),
        "f1_score": metrics.f1_score(targets, predictions, average="weighted")
    }

#@title Hyperparameters

learning_rate = 0.001 
num_epochs = 50
batch_size = 64
loss_function = nn.CrossEntropyLoss()

#@title Loaders

train_loader = torch.utils.data.DataLoader(train_dataset, batch_size=batch_size, shuffle=True)
test_loader = torch.utils.data.DataLoader(test_dataset, batch_size=batch_size, shuffle=False)

#@title Training loop

# Build the model
device = torch.device("mps" if torch.backends.mps.is_available() else "cpu")
print(device)
cnn = CNN()
cnn.to(device)

# Setting optimizer up
optimizer = torch.optim.Adam(cnn.parameters(), lr=learning_rate)

# Early stopping setup
best_loss = float('inf')
patience = 10
patience_counter = 0

# Start training epochs loop
for epoch in tqdm(range(num_epochs)):
  epoch_loss = 0.0
  for i, (images, labels) in enumerate(train_loader):
    images = images.to(device)
    labels = labels.to(device)

    # Forward pass
    optimizer.zero_grad()
    outputs = cnn(images)

    # Backward pass
    loss = loss_function(outputs, labels)
    loss.backward()

    optimizer.step()

    epoch_loss += loss.item()

    if (i+1) % 1000 == 0:
      tqdm.write(f' Epoch {epoch + 1}/{num_epochs}, Step {i+1}/{len(train_dataset) // batch_size}, Loss: {loss}')

  # Loss avrg
  epoch_loss /= len(train_loader)
  tqdm.write(f' Epoch {epoch+1} average loss: {epoch_loss:.4f}')

  # Early stopping using loss
  if epoch_loss < best_loss:
    best_loss = epoch_loss
    patience_counter = 0
  else:
    patience_counter += 1
    if patience_counter >= patience:
      tqdm.write("Early stopping triggered.")
      break

#@title Evaluate model (accuracy, precision, recall, etc)

cnn.eval()
predictions = []
labels = []
for images, label in test_loader:
  images = images.to(device)
  label = label.to(device)

  output = cnn(images)
  _, predicted = torch.max(output,1)

  predictions.extend(predicted.cpu().numpy())
  labels.extend(label.cpu().numpy())

scores = get_scores(labels, predictions)
print("Scores of your model\n", scores)

